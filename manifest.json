{
  "manifest_version": 2,
  "name": "My Custom Firefox",
  "version": "1.0.0",
  "description": "A tiny Hello World WebExtension for Firefox.",
  "permissions": ["tabs", "activeTab", "storage", "menus", "bookmarks", "<all_urls>"],
  "icons": {
    "16": "logo.png",
    "32": "logo.png",
    "48": "logo.png",
    "64": "logo.png",
    "128": "logo.png"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["tab_renamer.js"]
    }
  ],
  "browser_action": {
    "default_title": "My Custom Firefox",
    "default_icon": {
      "16": "logo.png",
      "32": "logo.png",
      "48": "logo.png",
      "64": "logo.png",
      "128": "logo.png"
    }
  }
}
